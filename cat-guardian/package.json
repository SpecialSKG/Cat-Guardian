{
  "name": "cat-guardian",
  "displayName": "Cat Guardian",
  "description": "A cute focus and break timer for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cat-guardian.startTimer",
        "title": "Cat Guardian: Start Timer"
      }
    ],
    "configuration": {
      "title": "Cat Guardian",
      "properties": {
        "catGuardian.workMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 0.1,
          "description": "Minutos de trabajo antes del descanso."
        },
        "catGuardian.breakSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "Segundos de descanso cuando termina el temporizador."
        },
        "catGuardian.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Inicia automáticamente el temporizador cuando VS Code termina de cargar."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
